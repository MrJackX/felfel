# ─── تنظیمات ربات فلفل (felfel) ───
# این فایل را به نام .env کپی کنید و مقادیر را پر کنید:
#   cp .env.example .env
#
# نکته: اگر با اسکریپت نصب (install.sh) نصب کنید، این فایل به‌صورت
# خودکار و با پرسیدن توکن و شناسه ادمین ساخته می‌شود.

# توکن ربات تلگرام (از @BotFather بگیرید)
TELEGRAM_BOT_TOKEN=123456789:AA...your-token-here

# شناسه عددی ادمین‌ها (از @userinfobot بگیرید) — چند ادمین را با کاما جدا کنید
BOT_ADMIN_IDS=123456789

# بررسی گواهی SSL سرور مقصد (اگر گواهی self-signed است: false)
VERIFY_SSL=true

# مسیر فایل دیتابیس
BOT_DB_PATH=felfel.sqlite
